---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Syed Bhai Biryani | Best Biryani in Town">
  
  <!-- Hero Section -->
  <section class="min-h-screen flex items-center justify-center bg-cover bg-center" 
           style="background-image: linear-gradient(rgba(0,0,0,0.55), rgba(0,0,0,0.45)), url('/biryani-hero.jpg')">
    <div class="text-center text-white px-6">
      <h1 class="text-6xl md:text-7xl font-bold mb-4">Syed Bhai Biryani</h1>
      <p class="text-2xl mb-8">Authentic • Fresh • Unforgettable</p>
      
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="#menu" class="px-8 py-4 bg-[#c2410f] hover:bg-[#9f2f0a] text-white rounded-full text-lg font-semibold transition">
          View Menu
        </a>
        <a href="https://wa.me/919876543210?text=Hi%20Syed%20Bhai%2C%20I%27d%20like%20to%20order%20biryani" 
           target="_blank"
           class="px-8 py-4 bg-[#25D366] hover:bg-[#128C7E] text-white rounded-full text-lg font-semibold flex items-center justify-center gap-2 transition">
          <span>Order on WhatsApp</span>
        </a>
      </div>
    </div>
  </section>

  <!-- About Section -->
  <section id="about" class="max-w-4xl mx-auto px-6 py-16 text-center">
    <h2 class="text-4xl font-bold mb-6">Our Story</h2>
    <p class="text-xl text-gray-700 leading-relaxed">
      At Syed Bhai Biryani, we bring generations of traditional recipes to your plate. 
      Every biryani is slow-cooked with the finest basmati rice, fresh meat, and our secret blend of aromatic spices.
    </p>
  </section>

  <!-- Menu Section -->
  <section id="menu" class="bg-[#fffaf0] py-16">
    <div class="max-w-6xl mx-auto px-6">
      <h2 class="text-4xl font-bold text-center mb-10">Signature Menu</h2>
      
      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
        <!-- Menu Item 1 -->
        <div class="bg-white p-6 rounded-2xl shadow">
          <h3 class="text-2xl font-semibold mb-2">Hyderabadi Chicken Biryani</h3>
          <p class="text-gray-600 mb-4">Tender chicken marinated in spices, slow-cooked with fragrant basmati rice.</p>
          <div class="flex justify-between items-center">
            <span class="text-3xl font-bold text-[#c2410f]">₹249</span>
            <a href="https://wa.me/919876543210?text=I%20want%20Hyderabadi%20Chicken%20Biryani" 
               target="_blank" class="text-[#c2410f] font-semibold hover:underline">Order →</a>
          </div>
        </div>

        <!-- Menu Item 2 -->
        <div class="bg-white p-6 rounded-2xl shadow">
          <h3 class="text-2xl font-semibold mb-2">Lucknowi Mutton Biryani</h3>
          <p class="text-gray-600 mb-4">Premium mutton slow-cooked with aromatic spices and saffron.</p>
          <div class="flex justify-between items-center">
            <span class="text-3xl font-bold text-[#c2410f]">₹299</span>
            <a href="https://wa.me/919876543210?text=I%20want%20Lucknowi%20Mutton%20Biryani" 
               target="_blank" class="text-[#c2410f] font-semibold hover:underline">Order →</a>
          </div>
        </div>

        <!-- Add more items similarly -->
      </div>
    </div>
  </section>

  <!-- Location Section -->
  <section id="location" class="max-w-4xl mx-auto px-6 py-16 text-center">
    <h2 class="text-4xl font-bold mb-6">Visit Us</h2>
    <p class="text-xl mb-4">Shop No. 12, Near City Mall, MG Road, Hyderabad</p>
    <p class="text-lg text-gray-600">Open Daily: 11:00 AM – 11:00 PM</p>
  </section>

</Layout>
